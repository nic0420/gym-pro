generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  dni           String    @unique
  phone         String?
  role          String    @default("CLIENT")
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   Membership[]
  attendances   Attendance[]
  payments      Payment[]
  reservations  Reservation[]
  classesTaught ClassSession[] @relation("ProfessorClasses")
}

model MembershipPlan {
  id          String       @id @default(uuid())
  name        String       
  description String?
  price       Float      
  durationDays Int         
  classLimit  Int?         
  createdAt   DateTime     @default(now())
  
  memberships Membership[]
}

model Membership {
  id               String           @id @default(uuid())
  userId           String
  planId           String
  startDate        DateTime
  endDate          DateTime
  status           String @default("ACTIVE")
  remainingClasses Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id])
  plan             MembershipPlan   @relation(fields: [planId], references: [id])
  payments         Payment[]
  
  @@index([userId, status])
}

model ClassType {
  id          String   @id @default(uuid())
  name        String   
  description String?
  colorHex    String?  
  
  sessions    ClassSession[]
}

model ClassSession {
  id          String   @id @default(uuid())
  classTypeId String
  professorId String
  startTime   DateTime
  endTime     DateTime
  capacity    Int
  createdAt   DateTime @default(now())

  classType   ClassType     @relation(fields: [classTypeId], references: [id])
  professor   User          @relation("ProfessorClasses", fields: [professorId], references: [id])
  reservations Reservation[]
  
  @@index([startTime])
}

model Reservation {
  id        String            @id @default(uuid())
  userId    String
  sessionId String
  status    String @default("CONFIRMED")
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id])
  session   ClassSession      @relation(fields: [sessionId], references: [id])
  
  @@unique([userId, sessionId])
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  timestamp DateTime @default(now())
  accessMethod String 
  granted   Boolean  @default(true)
  denialReason String? 

  user      User     @relation(fields: [userId], references: [id])
  
  @@index([timestamp])
}

model Payment {
  id           String   @id @default(uuid())
  userId       String
  membershipId String?
  amount       Float  
  method       String   
  status       String   
  paymentDate  DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id])
  membership   Membership? @relation(fields: [membershipId], references: [id])
}
